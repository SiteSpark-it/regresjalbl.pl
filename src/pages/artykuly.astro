---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTASection from '../components/CTASection.astro';
import FAQ from '../components/FAQ.astro';
import PageIntro from '../components/PageIntro.astro';
import { articleCards } from '../content/siteData';
import { articleSchema, breadcrumbSchema, faqSchema, personSchema, serviceSchema, websiteSchema } from '../content/schema';

const title = 'Baza wiedzy — regresja LBL, PLR i integracja duchowa';
const description =
  'Baza wiedzy o regresji LBL, Life Between Lives, regresji poprzednich wcieleń, sesjach online i odpowiedzialnej integracji.';
const breadcrumbs = [{ href: '/artykuly/', label: 'Baza wiedzy' }];
const pageFaq = [
  {
    question: 'Czy baza wiedzy jest blogiem sprzedażowym?',
    answer:
      'Nie. Jej celem jest uporządkowanie pojęć i pytań, które realnie pojawiają się przed sesją. Kontakt do konsultacji jest dostępny na stronie, ale treści mają przede wszystkim pomóc w spokojnej decyzji.'
  },
  {
    question: 'Od którego artykułu zacząć?',
    answer:
      'Jeśli dopiero poznajesz temat, zacznij od Life Between Lives i różnicy między PLR a LBL. Jeśli interesuje Cię oferta autorska, przejdź potem do opisu Brama Dusz LBL i strony o sesji.'
  }
];

const readingPaths = [
  {
    title: 'Najpierw uporządkuj pojęcia',
    text: 'Zacznij od różnicy między LBL, Life Between Lives i regresją poprzednich wcieleń. To pomaga czytać dalsze materiały bez mieszania pojęć.',
    links: [
      { href: '/life-between-lives/', label: 'Life Between Lives' },
      { href: '/regresja-poprzednich-wcielen/', label: 'Regresja poprzednich wcieleń' }
    ]
  },
  {
    title: 'Potem zobacz metodę autorską',
    text: 'Jeśli interesuje Cię Brama Dusz LBL, przeczytaj opis metody wprost: jako autorskiej pracy inspirowanej publikacjami dr. Michaela Newtona.',
    links: [
      { href: '/brama-dusz-lbl/', label: 'Brama Dusz LBL' },
      { href: '/regresja-miedzy-wcieleniami/', label: 'Między wcieleniami' }
    ]
  },
  {
    title: 'Na końcu sprawdź praktykę sesji',
    text: 'Przed kontaktem warto spokojnie zobaczyć, jak wygląda przygotowanie, czego nie obiecuje sesja i kiedy lepiej zadać dodatkowe pytania.',
    links: [
      { href: '/sesja/', label: 'Opis sesji' },
      { href: '/faq/', label: 'FAQ' }
    ]
  }
];
---

<BaseLayout
  title={title}
  description={description}
  path="/artykuly/"
  schema={[websiteSchema(), personSchema(), serviceSchema('/artykuly/'), breadcrumbSchema(breadcrumbs), articleSchema('/artykuly/', title, description), faqSchema(pageFaq)]}
>
  <Breadcrumbs items={breadcrumbs} />
  <PageIntro
    title="Baza wiedzy o regresji LBL, PLR i integracji duchowej"
    text="Materiały dla osób, które chcą najpierw zrozumieć pojęcia, granice i język pracy regresyjnej, zanim podejmą decyzję o sesji."
  />
  <section class="section-space bg-warm-50">
    <div class="container-page">
      <div class="grid gap-4 md:grid-cols-2">
        {articleCards.map((card) => <ArticleCard {...card} />)}
      </div>
    </div>
  </section>
  <section class="section-space bg-white" aria-labelledby="reading-paths-title">
    <div class="container-page grid gap-12 lg:grid-cols-[0.36fr_0.64fr]">
      <div>
        <div class="gold-line"></div>
        <h2 id="reading-paths-title" class="display-title mt-5 text-4xl text-ink-950 md:text-5xl">Jak czytać tę bazę wiedzy?</h2>
      </div>
      <div class="grid gap-4">
        {readingPaths.map((item, index) => (
          <article class="rounded-md border border-ink-950/10 bg-warm-50 p-5">
            <p class="text-xs font-bold uppercase tracking-[0.16em] text-gold-700">Krok {index + 1}</p>
            <h3 class="mt-2 text-lg font-bold text-ink-950">{item.title}</h3>
            <p class="mt-3 text-sm leading-7 text-slate-600">{item.text}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {item.links.map((link) => (
                <a class="button-quiet min-h-0 px-3 py-2 text-sm" href={link.href}>{link.label}</a>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
  <FAQ items={pageFaq} title="FAQ o bazie wiedzy" />
  <CTASection title="Po lekturze możesz spokojnie dopytać o sesję" />
</BaseLayout>
