---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTASection from '../components/CTASection.astro';
import FAQ from '../components/FAQ.astro';
import PageIntro from '../components/PageIntro.astro';
import { knowledgeArticles } from '../content/articles';
import { articleCards } from '../content/siteData';
import { articleSchema, breadcrumbSchema, faqSchema, organizationSchema, websiteSchema } from '../content/schema';

const title = 'Baza wiedzy o regresji LBL — sesja i integracja';
const description =
  'Praktyczna baza wiedzy o regresji LBL: pytania do sesji, regresja online, obrazy i odczucia, integracja oraz wybór prowadzącego.';
const breadcrumbs = [{ href: '/artykuly/', label: 'Baza wiedzy' }];
const pageFaq = [
  {
    question: 'Od którego artykułu zacząć?',
    answer:
      'Jeśli rozważasz pierwszą sesję, zacznij od tekstu o przygotowaniu pytań i wyborze prowadzącego. Jeśli obawiasz się, że nic nie zobaczysz, przeczytaj materiał o różnych sposobach doświadczania regresji. Osobom po sesji najbardziej przyda się przewodnik po integracji.'
  },
  {
    question: 'Czy artykuły zastępują konsultację?',
    answer:
      'Nie. Artykuły porządkują pojęcia i pomagają przygotować lepsze pytania, ale nie oceniają indywidualnej sytuacji. Krótka konsultacja pozwala omówić formę spotkania, warunki online lub stacjonarne i sprawdzić, czy regresja jest właściwym krokiem.'
  },
  {
    question: 'Czy materiały wymagają wiary w reinkarnację?',
    answer:
      'Nie. Treści uwzględniają duchowe, symboliczne i otwarte rozumienie doświadczenia. Nie trzeba przyjmować jednej interpretacji. Ważne jest zachowanie własnego rozeznania, jasnych granic i odniesienie wniosków do obecnego życia.'
  }
];
---

<BaseLayout
  title={title}
  description={description}
  path="/artykuly/"
  schema={[
    websiteSchema(),
    organizationSchema(),
    breadcrumbSchema(breadcrumbs),
    articleSchema('/artykuly/', title, description),
    faqSchema(pageFaq)
  ]}
>
  <Breadcrumbs items={breadcrumbs} />
  <PageIntro
    title="Baza wiedzy o regresji LBL"
    text="Odpowiedzi na pytania, które pojawiają się przed sesją i po niej: bez skrótów, sztucznego mistycyzmu i przekonywania do jednej interpretacji."
    ctaLabel="Przejdź do konsultacji"
  />

  <section class="section-space bg-warm-50" aria-labelledby="articles-title">
    <div class="container-page">
      <div class="max-w-3xl">
        <p class="text-xs font-bold uppercase tracking-[0.16em] text-gold-700">Praktyczne przewodniki</p>
        <h2 id="articles-title" class="display-title mt-5 text-4xl text-ink-950 md:text-5xl">Zacznij od pytania, które naprawdę Cię dotyczy</h2>
        <p class="mt-6 lead-text">
          Każdy artykuł odpowiada na inną intencję wyszukiwania i prowadzi do dalszego materiału. Nie powtarzamy tego samego opisu regresji pod kolejnymi tytułami.
        </p>
      </div>
      <div class="mt-10 grid gap-x-8 md:grid-cols-2">
        {knowledgeArticles.map((article) => (
          <ArticleCard
            title={article.title}
            description={article.excerpt}
            href={`/artykuly/${article.slug}/`}
            meta={`${article.category} · ${article.readingTime}`}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section-space bg-white" aria-labelledby="foundations-title">
    <div class="container-page grid gap-12 lg:grid-cols-[0.34fr_0.66fr]">
      <div>
        <div class="gold-line"></div>
        <h2 id="foundations-title" class="display-title mt-5 text-4xl text-ink-950 md:text-5xl">Najpierw potrzebujesz podstaw?</h2>
        <p class="mt-5 text-base leading-8 text-slate-600">
          Te przewodniki wyjaśniają główne pojęcia, metodę i przebieg sesji. Warto od nich zacząć, jeśli dopiero poznajesz temat.
        </p>
      </div>
      <div class="grid gap-x-8 md:grid-cols-2">
        {articleCards.map((card) => <ArticleCard {...card} />)}
      </div>
    </div>
  </section>

  <section class="section-space bg-[#edf7fa]" aria-labelledby="path-title">
    <div class="container-page">
      <div class="max-w-3xl">
        <div class="gold-line"></div>
        <h2 id="path-title" class="display-title mt-5 text-4xl text-ink-950 md:text-5xl">Prosta ścieżka od lektury do decyzji</h2>
      </div>
      <div class="mt-10 grid gap-5 md:grid-cols-3">
        <article class="decision-card p-6">
          <span class="text-sm font-bold text-gold-700">01</span>
          <h3 class="mt-3 text-xl font-bold text-ink-950">Uporządkuj pojęcia</h3>
          <p class="mt-3 text-sm leading-7 text-slate-700">Przeczytaj o LBL, poprzednich wcieleniach i metodzie Brama Dusz LBL. Sprawdź, który kierunek najbardziej odpowiada Twojemu pytaniu.</p>
        </article>
        <article class="decision-card p-6">
          <span class="text-sm font-bold text-gold-700">02</span>
          <h3 class="mt-3 text-xl font-bold text-ink-950">Nazwij własną intencję</h3>
          <p class="mt-3 text-sm leading-7 text-slate-700">Nie potrzebujesz gotowej historii. Wystarczy opisać powracający temat, relację, pytanie o sens lub ciekawość wobec doświadczenia.</p>
        </article>
        <article class="decision-card p-6">
          <span class="text-sm font-bold text-gold-700">03</span>
          <h3 class="mt-3 text-xl font-bold text-ink-950">Porozmawiaj przed zapisem</h3>
          <p class="mt-3 text-sm leading-7 text-slate-700">Konsultacja służy sprawdzeniu formy, przygotowania i terminu. Nie musisz decydować o pełnej sesji przed pierwszym kontaktem.</p>
        </article>
      </div>
    </div>
  </section>

  <FAQ items={pageFaq} title="FAQ o bazie wiedzy" />
  <CTASection
    title="Masz już konkretne pytanie?"
    text="Napisz kilka zdań przez formularz na tej stronie. Odpowiedź pomoże ustalić, czy warto umówić rozmowę i jaka forma spotkania będzie najbardziej odpowiednia."
  />
</BaseLayout>
