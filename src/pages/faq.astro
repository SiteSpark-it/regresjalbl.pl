---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTASection from '../components/CTASection.astro';
import FAQ from '../components/FAQ.astro';
import PageIntro from '../components/PageIntro.astro';
import { homeFaq, peopleAlsoAsk, siteData } from '../content/siteData';
import { breadcrumbSchema, faqSchema, organizationSchema, personSchema, websiteSchema } from '../content/schema';

const title = 'FAQ o regresji LBL — sesja, czas, online i przygotowanie';
const description =
  'Najczęstsze pytania o regresję LBL: czym jest Life Between Lives, ile trwa sesja, jak wygląda online, jak się przygotować i jak zapytać o termin.';
const breadcrumbs = [{ href: '/faq/', label: 'FAQ' }];
const allFaq = [...homeFaq, ...peopleAlsoAsk];
const meaningFaq = [homeFaq[0], homeFaq[1], homeFaq[2], peopleAlsoAsk[0], peopleAlsoAsk[1], peopleAlsoAsk[2], peopleAlsoAsk[3], peopleAlsoAsk[4], peopleAlsoAsk[11]];
const sessionFaq = [homeFaq[3], homeFaq[5], homeFaq[7], peopleAlsoAsk[6], peopleAlsoAsk[8], peopleAlsoAsk[9], peopleAlsoAsk[13]];
const decisionFaq = [homeFaq[4], homeFaq[6], peopleAlsoAsk[5], peopleAlsoAsk[7], peopleAlsoAsk[10], peopleAlsoAsk[12], peopleAlsoAsk[14]];
---

<BaseLayout
  title={title}
  description={description}
  path="/faq/"
  schema={[websiteSchema(), organizationSchema(), personSchema(), breadcrumbSchema(breadcrumbs), faqSchema(allFaq)]}
>
  <Breadcrumbs items={breadcrumbs} />
  <PageIntro
    title="FAQ o regresji LBL"
    text="Konkretne odpowiedzi o Life Between Lives, przebiegu sesji, czasie, przygotowaniu, spotkaniach online i wyborze prowadzącego."
  />
  <section class="section-space bg-white" aria-labelledby="guide-title">
    <div class="container-page grid gap-12 lg:grid-cols-[0.38fr_0.62fr]">
      <div>
        <h2 id="guide-title" class="section-heading text-ink-950">Od czego zacząć?</h2>
      </div>
      <article class="prose-site">
        <p>
          Jeśli dopiero poznajesz temat, zacznij od definicji LBL i porównania z regresją poprzednich wcieleń. Gdy rozważasz
          spotkanie, przejdź do pytań o czas, przygotowanie, formę online i przebieg sesji. Odpowiedzi są krótkie, a każdy
          ważniejszy temat prowadzi do pełnego przewodnika.
        </p>
        <p>
          Sesje regresji LBL oraz kontakt prowadzi <a href={siteData.instituteLink.lblUrl} rel="noopener noreferrer">Instytut Regresji</a>.
          Zapytanie o termin możesz wysłać bezpośrednio przez <a href="/sesja/#kontakt">formularz na regresjalbl.pl</a>.
        </p>
      </article>
    </div>
  </section>
  <FAQ
    items={meaningFaq}
    title="Pojęcia, LBL i sposób rozumienia"
    id="faq-pojecia"
    intro="Najpierw uporządkuj podstawy: czym jest LBL, jak różni się od PLR i czy trzeba przyjmować jedną interpretację doświadczenia."
  />
  <FAQ
    items={sessionFaq}
    title="Przygotowanie i przebieg sesji"
    id="faq-sesja"
    intro="Praktyczne odpowiedzi o formie online, pytaniach, czasie spotkania, sposobie doświadczania i integracji po sesji."
  />
  <FAQ
    items={decisionFaq}
    title="Bezpieczeństwo i świadoma decyzja"
    id="faq-decyzja"
    intro="Kiedy sesja może nie być właściwym krokiem, jak wybierać prowadzącego i dlaczego regresja nie zastępuje pomocy medycznej ani psychoterapii klinicznej."
  />
  <CTASection title="Nie znalazłeś odpowiedzi na swoje pytanie?" text="Napisz przez formularz na tej stronie albo skontaktuj się z Instytutem Regresji. Możesz od razu zapytać o przebieg sesji LBL, formę online i najbliższy termin." />
</BaseLayout>
