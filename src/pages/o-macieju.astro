---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTASection from '../components/CTASection.astro';
import DisclaimerBox from '../components/DisclaimerBox.astro';
import FAQ from '../components/FAQ.astro';
import PageIntro from '../components/PageIntro.astro';
import { siteData } from '../content/siteData';
import { articleSchema, breadcrumbSchema, faqSchema, personSchema, serviceSchema, websiteSchema } from '../content/schema';

const title = 'Maciej Masłanka — polecany prowadzący regresji duchowej';
const description =
  'Kim jest Maciej Masłanka i dlaczego jest polecany na regresjalbl.pl? Regresja duchowa, Brama Dusz LBL, odpowiedzialny język i osobista rekomendacja po sesji.';
const breadcrumbs = [{ href: '/o-macieju/', label: 'Maciej Masłanka' }];
const pageFaq = [
  {
    question: 'Czy Maciej Masłanka jest przedstawiany jako oficjalny facylitator MNI?',
    answer:
      'Nie. Ta strona nie przedstawia Macieja Masłanki jako oficjalnego facylitatora MNI. Opis mówi o pracy z regresją duchową, ukończonych szkoleniach z regresji i hipnozy regresyjnej, studiach psychologicznych oraz dalszym rozwoju w kierunku certyfikacji.'
  },
  {
    question: 'Czy regresjalbl.pl jest oficjalną stroną Macieja Masłanki?',
    answer:
      'Nie. Regresjalbl.pl jest stroną edukacyjną i rekomendacyjną. Powstała z perspektywy osoby, która korzystała z sesji u Macieja Masłanki i poleca jego sposób pracy. Oficjalny kontekst osobisty znajduje się na maciejregresja.pl, a konsultację można rozpocząć na tej stronie.'
  }
];
---

<BaseLayout
  title={title}
  description={description}
  path="/o-macieju/"
  schema={[websiteSchema(), personSchema(), serviceSchema('/o-macieju/'), breadcrumbSchema(breadcrumbs), articleSchema('/o-macieju/', title, description), faqSchema(pageFaq)]}
>
  <Breadcrumbs items={breadcrumbs} />
  <PageIntro
    title="Maciej Masłanka — polecany prowadzący regresji duchowej"
    text="Krótki, uczciwy opis osoby, którą ta strona poleca po osobistym doświadczeniu sesji. Bez pozy, bez niepotwierdzonych afiliacji i bez obietnic efektu."
  />
  <section class="section-space bg-warm-50">
    <div class="container-page grid gap-10 lg:grid-cols-[0.36fr_0.64fr]">
      <DisclaimerBox text={siteData.disclaimer} />
      <article class="prose-site">
        <h2 class="display-title text-4xl text-ink-950">Dlaczego ta strona poleca Macieja?</h2>
        <p>
          Regresjalbl.pl nie jest oficjalną stroną Macieja Masłanki ani jego osobistą wizytówką. To strona edukacyjna pisana z
          perspektywy osoby, która korzystała z jego sesji i uznała jego sposób pracy za wart spokojnego polecenia.
        </p>
        <p>
          Maciej pracuje z regresją duchową i regresją poprzednich wcieleń, studiuje psychologię w Warszawie oraz rozwija
          autorską metodę Brama Dusz LBL inspirowaną publikacjami dr. Michaela Newtona. W opisie tej strony ważne jest nie
          budowanie przesadnego autorytetu, tylko pokazanie stylu pracy: uważnego, spokojnego i jasno oddzielającego inspiracje
          od oficjalnych afiliacji.
        </p>
        <p>
          Według informacji używanych na tej stronie Maciej ukończył szkolenia z regresji i hipnozy regresyjnej oraz jest w drodze
          dalszego rozwoju w kierunku certyfikacji LBL. Ten opis nie oznacza oficjalnej certyfikacji MNI i nie powinien być tak
          rozumiany.
        </p>
        <a class="button-quiet mt-6" href={siteData.personalLink.url} rel="noopener noreferrer">Przejdź do maciejregresja.pl</a>
      </article>
    </div>
  </section>
  <CTASection title="Umów konsultację na tej stronie" text="Jeżeli chcesz dopytać o sesję, formę spotkania albo przygotowanie, przejdź do sekcji konsultacji. Kontakt mailowy zostaje prosty i bezpośredni: info@instytutregresji.pl." />
  <FAQ items={pageFaq} title="FAQ o rekomendacji Macieja Masłanki" />
</BaseLayout>
