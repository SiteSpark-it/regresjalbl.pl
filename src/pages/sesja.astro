---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTASection from '../components/CTASection.astro';
import FAQ from '../components/FAQ.astro';
import LeadForm from '../components/LeadForm.astro';
import PageIntro from '../components/PageIntro.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { siteData } from '../content/siteData';
import { articleSchema, breadcrumbSchema, faqSchema, personSchema, serviceSchema, websiteSchema } from '../content/schema';

const title = 'Sesja regresji LBL — przebieg, czas i przygotowanie';
const description = 'Jak wygląda sesja regresji LBL? Poznaj przebieg, czas 2,5–3,5 godziny, przygotowanie, formę online i w Rzeszowie oraz kontakt w sprawie terminu.';
const breadcrumbs = [{ href: '/sesja/', label: 'Sesja regresji LBL' }];
const pageFaq = [
  {
    question: 'Ile trwa sesja regresji LBL?',
    answer: 'Standardowa sesja regresji LBL trwa zwykle od 2,5 do 3,5 godziny. Obejmuje rozmowę przygotowującą, stopniowe wejście w stan skupienia, właściwą pracę z doświadczeniem życia między wcieleniami oraz spokojny powrót. W dniu spotkania warto zostawić sobie także wolniejszy czas po sesji, bez ważnych obowiązków.'
  },
  {
    question: 'Czy sesja regresji LBL może odbyć się online?',
    answer: 'Tak. Instytut Regresji prowadzi sesje LBL online oraz stacjonarnie w Rzeszowie. Do spotkania online potrzebujesz prywatnego, cichego miejsca, stabilnego internetu, słuchawek lub dobrego mikrofonu i kilku godzin bez przerw. Szczegóły techniczne oraz plan na wypadek przerwania połączenia są omawiane przed terminem.'
  },
  {
    question: 'Jak przygotować się do sesji LBL?',
    answer: 'Przed sesją zadbaj o sen, lekki posiłek, wodę i dzień bez pośpiechu. Zapisz kilka pytań dotyczących relacji, powtarzających się tematów lub poczucia celu, ale nie próbuj wcześniej układać historii. Przy spotkaniu online przygotuj wygodne miejsce i poinformuj domowników, że przez kilka godzin potrzebujesz ciszy.'
  },
  {
    question: 'Ile kosztuje sesja regresji LBL?',
    answer: 'Cena sesji LBL w Instytucie Regresji zaczyna się od 1110 zł. Przed rezerwacją otrzymasz informację o aktualnej kwocie, dostępnych terminach i wybranej formie spotkania. Możesz zapytać o wszystko przez formularz na tej stronie, telefonicznie albo przez WhatsApp, zanim zdecydujesz się na konkretny termin.'
  },
  {
    question: 'Czy podczas sesji trzeba widzieć wyraźne obrazy?',
    answer: 'Nie. Część osób doświadcza wyraźnych scen, inni odbierają sesję przez emocje, słowa, odczucia w ciele, skojarzenia lub poczucie wiedzy bez obrazu. Prowadzący pracuje z tym sposobem odbioru, który pojawia się naturalnie. Sesja nie jest testem wyobraźni i nie wymaga tworzenia spektakularnych wizji.'
  }
];
---

<BaseLayout
  title={title}
  description={description}
  path="/sesja/"
  schema={[websiteSchema(), personSchema(), serviceSchema('/sesja/'), breadcrumbSchema(breadcrumbs), articleSchema('/sesja/', title, description), faqSchema(pageFaq)]}
>
  <Breadcrumbs items={breadcrumbs} />
  <PageIntro
    title="Sesja regresji LBL — przebieg, czas i przygotowanie"
    text="Tutaj znajdziesz konkretny opis całego spotkania: od pierwszej rozmowy, przez doświadczenie Life Between Lives, po powrót i integrację. Sesje odbywają się online oraz stacjonarnie w Rzeszowie."
    ctaLabel="Zapytaj o termin sesji"
    ctaHref="#kontakt"
  />

  <section class="border-b border-ink-950/10 bg-[#edf7fa] py-7" aria-label="Najważniejsze informacje o sesji">
    <dl class="container-page grid gap-5 sm:grid-cols-3">
      <div><dt class="text-xs font-bold text-slate-600">Czas</dt><dd class="mt-1 text-lg font-bold text-ink-950">{siteData.session.duration}</dd></div>
      <div><dt class="text-xs font-bold text-slate-600">Miejsce</dt><dd class="mt-1 text-lg font-bold text-ink-950">{siteData.session.format}</dd></div>
      <div><dt class="text-xs font-bold text-slate-600">Cena</dt><dd class="mt-1 text-lg font-bold text-ink-950">{siteData.session.price}</dd></div>
    </dl>
  </section>

  <section class="section-space bg-warm-50" aria-labelledby="session-purpose-title">
    <div class="container-page grid gap-10 lg:grid-cols-[0.36fr_0.64fr] lg:gap-16">
      <div>
        <h2 id="session-purpose-title" class="section-heading text-ink-950">Na czym polega sesja LBL?</h2>
      </div>
      <article class="prose-site">
        <p>
          Sesja regresji LBL jest pogłębioną pracą z doświadczeniem życia między wcieleniami. Zwykle rozpoczyna się od
          uporządkowania intencji i pytań, a następnie prowadzi przez relaksację, skupienie uwagi i kolejne etapy wewnętrznego
          doświadczenia. Uczestnik pozostaje w kontakcie z prowadzącym i może opisywać to, co widzi, czuje lub rozumie.
        </p>
        <p>
          Tematem mogą być relacje, powtarzające się życiowe wzorce, poczucie kierunku, ważne wybory albo pytania o własną
          duchową historię. Prowadzący zadaje pytania pomocnicze i pilnuje ciągłości pracy, ale nie narzuca odpowiedzi ani
          gotowej interpretacji tego, co się pojawia.
        </p>
        <p>
          Spotkanie jest prowadzone jako sesja rozwojowa i duchowa. Nie służy diagnozowaniu chorób ani zastępowaniu leczenia
          czy psychoterapii. Wątpliwości dotyczące gotowości do sesji można omówić w pierwszym kontakcie.
        </p>
      </article>
    </div>
  </section>

  <section class="section-space bg-white" aria-labelledby="session-steps-title">
    <div class="container-page">
      <div class="max-w-3xl">
        <h2 id="session-steps-title" class="section-heading text-ink-950">Przebieg sesji krok po kroku</h2>
        <p class="mt-5 lead-text">Każdy etap ma swoje zadanie. Dzięki temu spotkanie nie zaczyna się nagle i nie kończy w chwili otwarcia oczu.</p>
      </div>
      <ol class="mt-9 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
        <li class="border-t-2 border-gold-500 pt-5"><span class="text-sm font-bold text-gold-700">01</span><h3 class="mt-2 text-xl font-bold text-ink-950">Rozmowa wstępna</h3><p class="mt-3 text-sm leading-7 text-slate-700">Pytania, intencja, dotychczasowe doświadczenia i praktyczne zasady spotkania. To moment na doprecyzowanie tego, czego szukasz.</p></li>
        <li class="border-t-2 border-gold-500 pt-5"><span class="text-sm font-bold text-gold-700">02</span><h3 class="mt-2 text-xl font-bold text-ink-950">Pogłębienie skupienia</h3><p class="mt-3 text-sm leading-7 text-slate-700">Oddech, relaksacja i prowadzenie uwagi pomagają ograniczyć rozproszenia oraz wejść głębiej w doświadczenie.</p></li>
        <li class="border-t-2 border-gold-500 pt-5"><span class="text-sm font-bold text-gold-700">03</span><h3 class="mt-2 text-xl font-bold text-ink-950">Praca Life Between Lives</h3><p class="mt-3 text-sm leading-7 text-slate-700">Sesja rozwija pojawiające się obrazy i odczucia, prowadząc ku pytaniom o przestrzeń między wcieleniami, relacje i cel.</p></li>
        <li class="border-t-2 border-gold-500 pt-5"><span class="text-sm font-bold text-gold-700">04</span><h3 class="mt-2 text-xl font-bold text-ink-950">Powrót i omówienie</h3><p class="mt-3 text-sm leading-7 text-slate-700">Na końcu jest czas na spokojny powrót, zebranie najważniejszych wątków i ustalenie, jak podejść do integracji.</p></li>
      </ol>
    </div>
  </section>

  <section class="section-space bg-[#edf7fa]" aria-labelledby="preparation-title">
    <div class="container-page grid gap-10 lg:grid-cols-[0.38fr_0.62fr] lg:gap-16">
      <div>
        <h2 id="preparation-title" class="section-heading text-ink-950">Jak dobrze przygotować dzień sesji?</h2>
      </div>
      <article class="prose-site">
        <p>
          Dzień wcześniej ogranicz alkohol i inne substancje wpływające na koncentrację. Zadbaj o sen, lekki posiłek i wodę.
          Nie planuj sesji między spotkaniami zawodowymi. Samo doświadczenie trwa kilka godzin, a po nim przydaje się czas na
          ciszę, spacer lub zapisanie wrażeń.
        </p>
        <p>
          Przygotuj od kilku do kilkunastu pytań. Najlepiej sprawdzają się pytania otwarte: „co warto zrozumieć w tej relacji?”,
          „dlaczego ten temat wraca?” albo „co jest teraz najważniejsze w moim kierunku?”. Lista jest pomocą, nie scenariuszem,
          który trzeba zrealizować punkt po punkcie.
        </p>
        <p>
          Jeśli sesja odbywa się online, ustaw urządzenie stabilnie, podłącz je do zasilania i sprawdź dźwięk. Wybierz miejsce,
          w którym możesz wygodnie leżeć lub siedzieć i nikt nie wejdzie do pomieszczenia w trakcie pracy.
        </p>
      </article>
    </div>
  </section>

  <section class="section-space bg-warm-50" aria-labelledby="preparation-reading-title">
    <div class="container-page">
      <div class="max-w-3xl">
        <h2 id="preparation-reading-title" class="section-heading text-ink-950">Materiały przed spotkaniem</h2>
        <p class="mt-5 lead-text">Trzy praktyczne teksty, do których warto zajrzeć po rezerwacji terminu.</p>
      </div>
      <div class="mt-9 grid gap-x-8 md:grid-cols-3">
        <ArticleCard title="Jak przygotować pytania do sesji?" description="Przykłady intencji, pytania otwarte i sformułowania, które warto przeformułować." href="/artykuly/pytania-do-sesji-regresji/" meta="przed sesją" />
        <ArticleCard title="Jak przygotować regresję online?" description="Prywatność, sprzęt, pozycja ciała i plan na wypadek przerwania połączenia." href="/artykuly/jak-przygotowac-sie-do-regresji-online/" meta="online" />
        <ArticleCard title="Co robić po sesji?" description="Spokojna integracja, notatki i granice interpretacji doświadczenia." href="/artykuly/integracja-po-sesji-regresji/" meta="po sesji" />
      </div>
    </div>
  </section>

  <section id="kontakt" class="section-space bg-white" aria-labelledby="kontakt-title">
    <div class="container-page grid gap-10 lg:grid-cols-[0.4fr_0.6fr] lg:gap-14">
      <div>
        <p class="text-sm font-bold text-gold-700">Kontakt i terminy</p>
        <h2 id="kontakt-title" class="section-heading mt-3 text-ink-950">Zapytaj o sesję regresji LBL</h2>
        <p class="mt-5 lead-text">Napisz, czy interesuje Cię sesja online czy spotkanie w Rzeszowie. Instytut Regresji odpowie w sprawie dostępności, przygotowania i rezerwacji.</p>
        <div class="mt-7 grid gap-3 text-sm leading-7 text-slate-700">
          <p class="consultation-note rounded-md px-4 py-3"><strong class="text-ink-950">Nie musisz opisywać całej historii.</strong> Na początek wystarczy temat, preferowana forma i wygodny sposób kontaktu.</p>
          <p class="rounded-md border border-ink-950/10 bg-warm-50/60 px-4 py-3">Telefon i WhatsApp: <a class="font-bold text-gold-700 hover:text-ink-950" href={siteData.contact.phoneHref}>{siteData.contact.phone}</a><br />E-mail: <a class="font-bold text-gold-700 hover:text-ink-950" href={siteData.contact.emailHref}>{siteData.contact.email}</a></p>
        </div>
      </div>
      <LeadForm />
    </div>
  </section>

  <CTASection title="Masz pytanie przed rezerwacją?" text="Skontaktuj się z Instytutem Regresji i zapytaj o przebieg, formę online, spotkanie w Rzeszowie albo najbliższy dostępny termin. Pierwsza wiadomość może być krótka i konkretna." />
  <FAQ items={pageFaq} title="FAQ o sesji regresji LBL" />
</BaseLayout>
