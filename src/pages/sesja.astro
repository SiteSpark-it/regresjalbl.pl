---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTASection from '../components/CTASection.astro';
import DisclaimerBox from '../components/DisclaimerBox.astro';
import FAQ from '../components/FAQ.astro';
import LeadForm from '../components/LeadForm.astro';
import PageIntro from '../components/PageIntro.astro';
import { articleSchema, breadcrumbSchema, faqSchema, personSchema, serviceSchema, websiteSchema } from '../content/schema';

const title = 'Sesja regresji duchowej — przebieg, przygotowanie i konsultacja';
const description =
  'Jak wygląda sesja regresji duchowej i Brama Dusz LBL? Przygotowanie, przebieg, integracja, granice pracy i kontakt do konsultacji.';
const breadcrumbs = [{ href: '/sesja/', label: 'Sesja regresji duchowej' }];
const pageFaq = [
  {
    question: 'Jak przygotować się do sesji?',
    answer:
      'Warto zadbać o spokojny dzień, miejsce bez rozpraszaczy, wodę i czas po spotkaniu. Pomaga zapisanie intencji, ale bez sztywnego oczekiwania. Sesja nie jest egzaminem z wyobraźni ani testem duchowości.'
  },
  {
    question: 'Czy sesja może odbyć się online?',
    answer:
      'Tak, jeśli warunki są spokojne i bezpieczne. Potrzebne są prywatność, stabilne połączenie, wygodne miejsce i możliwość pozostania bez przerwań. Forma online powinna być wcześniej omówiona z prowadzącym.'
  },
  {
    question: 'Co dzieje się po sesji?',
    answer:
      'Po sesji ważna jest integracja: odpoczynek, zapisanie wrażeń, spokojna obserwacja emocji i unikanie pochopnych decyzji. Nie każde doświadczenie trzeba od razu wyjaśniać. Czasem sens układa się dopiero po kilku dniach.'
  }
];
---

<BaseLayout
  title={title}
  description={description}
  path="/sesja/"
  schema={[websiteSchema(), personSchema(), serviceSchema('/sesja/'), breadcrumbSchema(breadcrumbs), articleSchema('/sesja/', title, description), faqSchema(pageFaq)]}
>
  <Breadcrumbs items={breadcrumbs} />
  <PageIntro
    title="Sesja regresji duchowej — przebieg, przygotowanie i granice"
    text="Zanim zdecydujesz się na pełną sesję, możesz spokojnie sprawdzić formę pracy, przygotowanie i to, czy taki kierunek w ogóle pasuje do Twojej sytuacji."
  />
  <section class="section-space bg-warm-50">
    <div class="container-page grid gap-10 lg:grid-cols-[0.36fr_0.64fr]">
      <DisclaimerBox text="Sesja ma charakter rozwojowy i duchowy. Nie stanowi diagnozy, leczenia, porady medycznej ani psychoterapii klinicznej." />
      <article class="prose-site">
        <h2 class="display-title text-4xl text-ink-950">Dla kogo może być taka praca?</h2>
        <p>
          Sesja może zainteresować osoby, które szukają języka do rozmowy o sensie, duchowości, relacjach albo wewnętrznych
          obrazach. Nie jest formą interwencji kryzysowej ani zastępstwem profesjonalnego leczenia.
        </p>
        <p>
          Przed zapisem warto uczciwie przyjrzeć się oczekiwaniom, stanowi zdrowia i wcześniejszym doświadczeniom. Dobra
          decyzja potrzebuje informacji, spokoju i braku presji.
        </p>
      </article>
    </div>
  </section>
  <section class="section-space bg-white" aria-labelledby="session-steps-title">
    <div class="container-page">
      <div class="max-w-3xl">
        <div class="gold-line"></div>
        <h2 id="session-steps-title" class="display-title mt-5 text-4xl text-ink-950 md:text-5xl">Przebieg sesji krok po kroku</h2>
      </div>
      <div class="mt-10 grid gap-5 md:grid-cols-3">
        <article class="rounded-md border border-ink-950/10 bg-warm-50 p-6">
          <h3 class="text-xl font-bold text-ink-950">Rozmowa i intencja</h3>
          <p class="mt-3 text-sm leading-7 text-slate-600">Na początku porządkujemy intencję, pytania, granice i warunki pracy. To moment na szczerość, nie autoprezentację.</p>
        </article>
        <article class="rounded-md border border-ink-950/10 bg-warm-50 p-6">
          <h3 class="text-xl font-bold text-ink-950">Praca wewnętrzna</h3>
          <p class="mt-3 text-sm leading-7 text-slate-600">Właściwa część sesji może obejmować relaksację, obrazy, emocje, symbole i pytania, które pomagają uważnie przejść przez doświadczenie.</p>
        </article>
        <article class="rounded-md border border-ink-950/10 bg-warm-50 p-6">
          <h3 class="text-xl font-bold text-ink-950">Powrót i integracja</h3>
          <p class="mt-3 text-sm leading-7 text-slate-600">Po pracy jest czas na omówienie i domknięcie. Integracja pomaga wrócić do codzienności spokojnie, bez pochopnych decyzji.</p>
        </article>
      </div>
    </div>
  </section>
  <section class="section-space bg-warm-50" aria-labelledby="practical-title">
    <div class="container-page grid gap-12 lg:grid-cols-[0.38fr_0.62fr]">
      <div>
        <div class="gold-line"></div>
        <h2 id="practical-title" class="display-title mt-5 text-4xl text-ink-950 md:text-5xl">Czas, forma i koszt</h2>
      </div>
      <article class="prose-site">
        <p>
          Sesja regresji duchowej zwykle wymaga kilku godzin i nie powinna być wciskana między inne obowiązki. Najlepiej
          zaplanować ją w dniu, w którym jest miejsce na spokojny powrót, notatki i odpoczynek.
        </p>
        <p>
          Aktualna forma spotkania, dostępność terminów i koszt sesji powinny być ustalone indywidualnie przed decyzją. Dzięki temu
          na tej stronie nie ma nieaktualnych obietnic ani cen, które mogłyby wprowadzać w błąd.
        </p>
        <a class="button-quiet mt-6" href="#kontakt">Przejdź do kontaktu</a>
      </article>
    </div>
  </section>
  <section id="kontakt" class="section-space bg-white" aria-labelledby="kontakt-title">
    <div class="container-page grid gap-10 lg:grid-cols-[0.42fr_0.58fr]">
      <div>
        <div class="gold-line"></div>
        <h2 id="kontakt-title" class="display-title mt-5 text-4xl text-ink-950 md:text-5xl">Umów konsultację</h2>
        <p class="mt-6 lead-text">
          Jeżeli czujesz, że to temat dla Ciebie, nie odkładaj decyzji tylko dlatego, że nie masz jeszcze wszystkich odpowiedzi. Napisz krótko, czego szukasz, a konsultacja pomoże ustalić najbliższy sensowny krok.
        </p>
        <div class="mt-7 grid gap-3 text-sm leading-7 text-slate-700">
          <p class="consultation-note rounded-md px-4 py-3"><strong class="text-ink-950">Najlepiej napisać teraz, gdy temat jest świeży.</strong> Wystarczy kilka zdań i preferowana forma kontaktu.</p>
          <p class="rounded-md border border-ink-950/10 bg-white/70 px-4 py-3">Kontakt: <a class="font-bold text-gold-700 hover:text-ink-950" href="tel:+48455448119">+48 455 448 119</a> lub <a class="font-bold text-gold-700 hover:text-ink-950" href="mailto:info@instytutregresji.pl">info@instytutregresji.pl</a>.</p>
        </div>
      </div>
      <LeadForm />
    </div>
  </section>
  <CTASection title="Chcesz sprawdzić najbliższy możliwy krok?" text="Przejdź do formularza na tej stronie albo napisz bezpośrednio. Konsultacja ma pomóc ustalić, czy sesja, forma online i metoda Brama Dusz LBL są w Twojej sytuacji sensowne." />
  <FAQ items={pageFaq} title="FAQ o sesji regresji duchowej" />
</BaseLayout>
