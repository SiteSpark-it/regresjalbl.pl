---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTASection from '../components/CTASection.astro';
import DisclaimerBox from '../components/DisclaimerBox.astro';
import FAQ from '../components/FAQ.astro';
import PageIntro from '../components/PageIntro.astro';
import { siteData } from '../content/siteData';
import { articleSchema, breadcrumbSchema, faqSchema, personSchema, serviceSchema, websiteSchema } from '../content/schema';

const title = 'Brama Dusz LBL™ — autorska metoda regresji duchowej';
const description =
  'Brama Dusz LBL™ to autorska metoda regresji duchowej inspirowana publikacjami dr. Michaela Newtona, prowadzona spokojnie i z jasnymi granicami.';
const breadcrumbs = [{ href: '/brama-dusz-lbl/', label: 'Brama Dusz LBL™' }];
const pageFaq = [
  {
    question: 'Czy Brama Dusz LBL™ to oficjalne Life Between Lives®?',
    answer:
      'Nie. Brama Dusz LBL™ jest metodą autorską i nie jest oficjalną usługą The Michael Newton Institute. Nazwa wskazuje na inspirację tematyką pracy między wcieleniami, ale nie oznacza formalnej afiliacji ani oficjalnej certyfikacji MNI.'
  },
  {
    question: 'Na czym polega autorski charakter metody?',
    answer:
      'Autorski charakter polega na sposobie prowadzenia, języku rozmowy po sesji i łączeniu regresji duchowej z psychologicznym rozumieniem doświadczenia. Metoda jest inspirowana publikacjami dr. Michaela Newtona, ale pozostaje osobną formą pracy.'
  },
  {
    question: 'Czy w sesji trzeba mieć silne wizje?',
    answer:
      'Nie. Doświadczenie może przyjść jako obraz, odczucie, emocja, wspomnienie, symbol albo spokojna intuicja. Odpowiedzialna sesja nie wymusza przeżyć i nie ocenia uczestnika przez pryzmat intensywności wizji.'
  }
];
---

<BaseLayout
  title={title}
  description={description}
  path="/brama-dusz-lbl/"
  schema={[websiteSchema(), personSchema(), serviceSchema('/brama-dusz-lbl/'), breadcrumbSchema(breadcrumbs), articleSchema('/brama-dusz-lbl/', title, description), faqSchema(pageFaq)]}
>
  <Breadcrumbs items={breadcrumbs} />
  <PageIntro
    title="Brama Dusz LBL™ — autorska metoda regresji duchowej"
    text="Spokojna praca z doświadczeniem wewnętrznym, inspirowana publikacjami dr. Michaela Newtona i regresją poprzednich wcieleń. Bez obietnic, bez presji i bez udawania oficjalnej ścieżki MNI."
  />
  <section class="section-space bg-warm-50">
    <div class="container-page grid gap-10 lg:grid-cols-[0.38fr_0.62fr]">
      <DisclaimerBox text={siteData.disclaimer} />
      <article class="prose-site">
        <h2 class="display-title text-4xl text-ink-950">Czym jest ta metoda?</h2>
        <p>
          Brama Dusz LBL™ jest autorską metodą regresji duchowej. Nie jest przedstawiana jako oficjalna usługa The Michael
          Newton Institute ani formalna ścieżka Life Between Lives®.
        </p>
        <p>
          W centrum sesji znajduje się uważne prowadzenie przez obrazy, emocje, symbole i pytania dotyczące sensu. Celem
          nie jest mocne przeżycie za wszelką cenę, lecz spokojne zobaczenie tego, co rzeczywiście się pojawia, i późniejsze ułożenie tego w codziennym życiu.
        </p>
      </article>
    </div>
  </section>
  <section class="section-space bg-white" aria-labelledby="process-title">
    <div class="container-page">
      <div class="max-w-3xl">
        <div class="gold-line"></div>
        <h2 id="process-title" class="display-title mt-5 text-4xl text-ink-950 md:text-5xl">Jak wygląda praca?</h2>
        <p class="mt-6 lead-text">Sesja ma spokojny rytm: rozmowa, wejście w skupienie, praca z tym, co się pojawia, i łagodny powrót do codzienności.</p>
      </div>
      <div class="mt-10 grid gap-5 md:grid-cols-3">
        <article class="rounded-md border border-ink-950/10 p-6">
          <h3 class="text-xl font-bold text-ink-950">Przygotowanie</h3>
          <p class="mt-3 text-sm leading-7 text-slate-600">Przed sesją omawiamy intencję, oczekiwania, granice oraz warunki spokojnej pracy. Nie chodzi o narzucenie scenariusza.</p>
        </article>
        <article class="rounded-md border border-ink-950/10 p-6">
          <h3 class="text-xl font-bold text-ink-950">Prowadzenie</h3>
          <p class="mt-3 text-sm leading-7 text-slate-600">Sesja może obejmować relaksację, narrację, pracę z obrazem, symbolem, emocją i pytaniami, które pomagają trzymać kierunek.</p>
        </article>
        <article class="rounded-md border border-ink-950/10 p-6">
          <h3 class="text-xl font-bold text-ink-950">Integracja</h3>
          <p class="mt-3 text-sm leading-7 text-slate-600">Po sesji ważne jest spokojne domknięcie, odróżnienie symbolu od faktu i sprawdzenie, co naprawdę jest pomocne w życiu.</p>
        </article>
      </div>
    </div>
  </section>
  <section class="section-space bg-warm-50" aria-labelledby="author-boundaries-title">
    <div class="container-page grid gap-12 lg:grid-cols-[0.42fr_0.58fr]">
      <h2 id="author-boundaries-title" class="display-title text-4xl text-ink-950 md:text-5xl">Odpowiedzialny język metody</h2>
      <article class="prose-site">
        <p>
          Brama Dusz LBL™ nie obiecuje konkretnego przeżycia, odkrycia ani zmiany życiowej. Jest zaproszeniem do pracy z
          tym, co faktycznie się pojawia, bez presji na wyjątkowy duchowy efekt.
        </p>
        <p>
          Taki język jest ważny, bo regresja duchowa dotyka wrażliwych tematów: sensu, relacji, żałoby, wyborów, symboli i
          przekonań. Dobra sesja powinna zostawiać przestrzeń, a nie zamykać człowieka w jednej gotowej interpretacji.
        </p>
      </article>
    </div>
  </section>
  <CTASection title="Chcesz spokojnie zobaczyć, jak wygląda sesja?" />
  <FAQ items={pageFaq} title="FAQ o Brama Dusz LBL™" />
</BaseLayout>
