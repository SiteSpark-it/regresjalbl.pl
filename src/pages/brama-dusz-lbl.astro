---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Przekierowanie — Regresja LBL';
const description = 'Ten adres został zastąpiony stroną o klasycznej regresji LBL.';
---

<BaseLayout title={title} description={description} path="/brama-dusz-lbl/" noindex={true}>
  <section class="section-space bg-warm-50">
    <div class="container-page">
      <h1 class="section-heading text-ink-950">Regresja LBL</h1>
      <p class="mt-5 text-base leading-8 text-slate-700">
        Ten adres został przeniesiony. Przejdź do strony:
        <a class="font-bold text-gold-700 hover:text-ink-950" href="/regresja-lbl/">klasyczna regresja LBL</a>.
      </p>
    </div>
  </section>
</BaseLayout>
