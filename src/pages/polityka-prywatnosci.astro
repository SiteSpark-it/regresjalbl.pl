---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageIntro from '../components/PageIntro.astro';
import { siteData } from '../content/siteData';
import { breadcrumbSchema, personSchema, websiteSchema } from '../content/schema';

const title = 'Polityka prywatności — regresjalbl.pl';
const description = 'Informacje o kontakcie, linkach zewnętrznych, cookies i prywatności na statycznej stronie regresjalbl.pl.';
const breadcrumbs = [{ href: '/polityka-prywatnosci/', label: 'Polityka prywatności' }];
---

<BaseLayout title={title} description={description} path="/polityka-prywatnosci/" schema={[websiteSchema(), personSchema(), breadcrumbSchema(breadcrumbs)]}>
  <Breadcrumbs items={breadcrumbs} />
  <PageIntro
    title="Polityka prywatności"
    text="Krótka informacja o kontakcie, linkach zewnętrznych i sposobie korzystania ze statycznej strony regresjalbl.pl."
    ctaLabel="Wróć do przewodnika"
    ctaHref="/"
  />
  <section class="section-space bg-warm-50">
    <div class="container-page">
      <article class="prose-site max-w-3xl">
        <h2 class="display-title text-4xl text-ink-950">Kontakt</h2>
        <p>
          Kontakt w sprawie sesji i konsultacji: telefon i WhatsApp
          <a href={siteData.contact.phoneHref}>{siteData.contact.phone}</a>, e-mail
          <a href={siteData.contact.emailHref}>{siteData.contact.email}</a>. Sama ścieżka konsultacji jest opisana na regresjalbl.pl,
          a kontakt mailowy służy do ustalenia dalszych szczegółów.
        </p>

        <h2 class="display-title mt-10 text-4xl text-ink-950">Formularz konsultacji</h2>
        <p>
          Jeżeli korzystasz z formularza, przetwarzane są dane, które samodzielnie podasz: imię, e-mail, telefon, preferowana forma
          kontaktu, temat i treść wiadomości. Formularz służy wyłącznie do odpowiedzi w sprawie konsultacji. Na tym etapie nie należy
          wpisywać szczegółowych danych medycznych ani bardzo prywatnych informacji.
        </p>

        <h2 class="display-title mt-10 text-4xl text-ink-950">Analityka strony</h2>
        <p>
          Strona może zbierać statystyki odwiedzin dopiero po wyrażeniu zgody w banerze analitycznym. Dane obejmują między innymi:
          odwiedzaną podstronę, czas sesji, kliknięcia w kontakt, źródło wejścia, język przeglądarki, strefę czasową, rozmiar ekranu
          oraz przybliżony kraj, jeśli serwer hostingowy udostępnia taką informację. Surowy adres IP nie jest prezentowany w panelu
          statystyk.
        </p>

        <h2 class="display-title mt-10 text-4xl text-ink-950">Linki zewnętrzne</h2>
        <p>
          Strona może prowadzić do zewnętrznych serwisów, w tym maciejregresja.pl, Instytutu Regresji oraz oficjalnych źródeł
          informacyjnych dotyczących The Michael Newton Institute. Zewnętrzne serwisy działają według własnych zasad prywatności.
        </p>

        <h2 class="display-title mt-10 text-4xl text-ink-950">Cookies i pamięć przeglądarki</h2>
        <p>
          Zgoda lub odmowa pomiaru może być zapisana w pamięci przeglądarki. Właściciel strony może wyłączyć pomiar na swoim urządzeniu,
          wchodząc na stronę z parametrem <code>?analytics_ignore=1</code>. Taka decyzja dotyczy konkretnej przeglądarki i urządzenia.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>
