---
import { siteData } from '../content/siteData';

interface Props {
  title: string;
  text: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  title,
  text,
  ctaLabel = siteData.cta.label,
  ctaHref = siteData.cta.url
} = Astro.props;
---

<section class="section-space bg-white">
  <div class="container-page">
    <div class="gold-line"></div>
    <h1 class="display-title mt-6 max-w-5xl text-balance text-[clamp(2.25rem,5.4vw,4.75rem)] text-ink-950">{title}</h1>
    <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-600 md:text-xl md:leading-9">{text}</p>
    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
      <a class="button-primary w-full text-center sm:w-auto" href={ctaHref} aria-label="Przejdź do konsultacji na regresjalbl.pl">{ctaLabel}</a>
      <a class="button-quiet w-full text-center sm:w-auto" href="/faq/">Przeczytaj FAQ</a>
    </div>
  </div>
</section>
