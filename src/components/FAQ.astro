---
import type { FaqItem } from '../content/siteData';

interface Props {
  items: FaqItem[];
  title?: string;
  id?: string;
  intro?: string;
}

const {
  items,
  title = 'FAQ',
  id = 'faq',
  intro = 'Te odpowiedzi mają pomóc Ci spokojnie uporządkować temat. Nie zastępują konsultacji medycznej, psychoterapeutycznej ani diagnostycznej.'
} = Astro.props;
const titleId = `${id}-title`;
---

<section class="faq-section section-space bg-warm-50" id={id} aria-labelledby={titleId}>
  <div class="container-page grid gap-10 lg:grid-cols-[0.36fr_0.64fr]">
    <div>
      <div class="gold-line"></div>
      <h2 id={titleId} class="display-title mt-5 text-4xl text-ink-950 md:text-5xl">{title}</h2>
      <p class="mt-5 text-base leading-8 text-slate-600">{intro}</p>
    </div>
    <div class="grid gap-3">
      {items.map((item) => (
        <details class="group rounded-md border border-ink-950/10 bg-white p-5 shadow-sm">
          <summary class="flex cursor-pointer list-none items-start justify-between gap-4 text-left font-bold text-ink-900">
            <span>{item.question}</span>
            <span class="mt-1 grid h-6 w-6 shrink-0 place-items-center rounded-full border border-gold-600/35 text-gold-700 transition group-open:rotate-45" aria-hidden="true">+</span>
          </summary>
          <p class="mt-4 text-sm leading-7 text-slate-600">{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>
