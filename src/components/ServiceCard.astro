---
import type { CardItem } from '../content/siteData';

type Props = CardItem & {
  index?: number;
};

const { title, description, href, index = 1 } = Astro.props;
---

<article class="decision-card p-6 transition duration-200 hover:-translate-y-0.5 hover:border-gold-500/45 hover:shadow-soft">
  <span class="text-xs font-bold uppercase tracking-[0.16em] text-gold-700">0{index}</span>
  <h3 class="mt-4 text-xl font-bold text-ink-950">{title}</h3>
  <p class="mt-3 text-sm leading-7 text-slate-600">{description}</p>
  <a class="mt-5 inline-flex min-h-9 items-center text-sm font-bold text-gold-700 hover:text-ink-950" href={href} aria-label={`Czytaj więcej: ${title}`}>Czytaj dalej</a>
</article>
