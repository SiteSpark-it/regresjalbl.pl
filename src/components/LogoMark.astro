---
interface Props {
  class?: string;
  title?: string;
}

const { class: className = 'h-11 w-11', title = 'Regresja LBL' } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 96 96"
  role="img"
  aria-label={title}
  xmlns="http://www.w3.org/2000/svg"
>
  <defs>
    <linearGradient id="logo-bg" x1="16" x2="80" y1="12" y2="88" gradientUnits="userSpaceOnUse">
      <stop stop-color="#fffaf2" />
      <stop offset="0.58" stop-color="#eaf6f8" />
      <stop offset="1" stop-color="#d7edf2" />
    </linearGradient>
    <linearGradient id="logo-arch" x1="23" x2="73" y1="18" y2="84" gradientUnits="userSpaceOnUse">
      <stop stop-color="#172a3a" />
      <stop offset="1" stop-color="#3f7d96" />
    </linearGradient>
    <linearGradient id="logo-light" x1="48" x2="48" y1="24" y2="76" gradientUnits="userSpaceOnUse">
      <stop stop-color="#f2dcae" />
      <stop offset="0.52" stop-color="#ffffff" />
      <stop offset="1" stop-color="#86bdd0" />
    </linearGradient>
  </defs>
  <rect width="96" height="96" rx="22" fill="url(#logo-bg)" />
  <rect x="8.5" y="8.5" width="79" height="79" rx="17.5" fill="none" stroke="#172a3a" stroke-opacity="0.1" />
  <path
    d="M25 78V43.5C25 26.8 34.2 17 48 17s23 9.8 23 26.5V78"
    fill="none"
    stroke="url(#logo-arch)"
    stroke-width="7"
    stroke-linecap="round"
  />
  <path
    d="M36 78V45.5C36 35.9 40.7 30 48 30s12 5.9 12 15.5V78"
    fill="none"
    stroke="#ffffff"
    stroke-width="5"
    stroke-linecap="round"
    opacity="0.9"
  />
  <path
    d="M48 25v51"
    fill="none"
    stroke="url(#logo-light)"
    stroke-width="4"
    stroke-linecap="round"
  />
  <path
    d="M38 60c3.2-3.4 6.5-5.1 10-5.1S54.8 56.6 58 60"
    fill="none"
    stroke="#5f9bb3"
    stroke-width="3"
    stroke-linecap="round"
    opacity="0.82"
  />
</svg>
