---
import { siteData } from '../content/siteData';

interface Props {
  title?: string;
  text?: string;
}

const {
  title = 'Jak wygląda droga od pytania do sesji?',
  text = 'Nie musisz wybierać metody ani terminu w pierwszej wiadomości. Najpierw sprawdzane są Twoje pytanie, warunki spotkania i to, czy ten rodzaj pracy jest odpowiedni.'
} = Astro.props;
---

<section class="section-space bg-[#edf7fa]" aria-labelledby="consultation-path-title">
  <div class="container-page">
    <div class="grid gap-10 lg:grid-cols-[0.36fr_0.64fr]">
      <div>
        <div class="gold-line"></div>
        <h2 id="consultation-path-title" class="display-title mt-5 text-4xl text-ink-950 md:text-5xl">{title}</h2>
        <p class="mt-5 text-base leading-8 text-slate-700">{text}</p>
      </div>
      <div>
        <ol class="grid gap-5 sm:grid-cols-3">
          <li class="border-t border-ink-950/15 pt-5">
            <span class="text-sm font-bold text-gold-700">01</span>
            <h3 class="mt-2 text-lg font-bold text-ink-950">Krótka wiadomość</h3>
            <p class="mt-2 text-sm leading-7 text-slate-700">Opisujesz temat w kilku zdaniach i wybierasz wygodny sposób odpowiedzi.</p>
          </li>
          <li class="border-t border-ink-950/15 pt-5">
            <span class="text-sm font-bold text-gold-700">02</span>
            <h3 class="mt-2 text-lg font-bold text-ink-950">Spokojna konsultacja</h3>
            <p class="mt-2 text-sm leading-7 text-slate-700">Ustalasz formę, przygotowanie i pytania. Nadal nie musisz rezerwować pełnej sesji.</p>
          </li>
          <li class="border-t border-ink-950/15 pt-5">
            <span class="text-sm font-bold text-gold-700">03</span>
            <h3 class="mt-2 text-lg font-bold text-ink-950">Decyzja i termin</h3>
            <p class="mt-2 text-sm leading-7 text-slate-700">Jeśli kierunek jest właściwy, ustalane są warunki oraz najbliższy dostępny termin.</p>
          </li>
        </ol>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <a class="button-primary" href={siteData.cta.url}>Przejdź do formularza</a>
          <a class="button-secondary" href={siteData.contact.whatsappHref} rel="noopener noreferrer">Napisz przez WhatsApp</a>
          <a class="button-quiet" href={siteData.contact.phoneHref}>Zadzwoń: {siteData.contact.phone}</a>
        </div>
        <p class="mt-4 text-xs leading-6 text-slate-600">
          Kontakt organizacyjny i odpowiedzi na zgłoszenia prowadzi
          <a class="font-bold text-ink-900 hover:text-gold-700" href={siteData.instituteLink.url} rel="noopener noreferrer"> Instytut Regresji</a>.
        </p>
      </div>
    </div>
  </div>
</section>
