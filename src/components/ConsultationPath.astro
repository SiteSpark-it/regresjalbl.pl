---
import { siteData } from '../content/siteData';

interface Props {
  title?: string;
  text?: string;
}

const {
  title = 'Jak umówić sesję LBL?',
  text = 'W pierwszej wiadomości podaj preferowaną formę spotkania i krótko opisz temat. Instytut Regresji odpowie w sprawie przygotowania, aktualnych terminów i rezerwacji.'
} = Astro.props;
---

<section class="section-space bg-[#edf7fa]" aria-labelledby="consultation-path-title">
  <div class="container-page">
    <div class="grid gap-10 lg:grid-cols-[0.36fr_0.64fr]">
      <div>
        <h2 id="consultation-path-title" class="section-heading text-ink-950">{title}</h2>
        <p class="mt-5 text-base leading-8 text-slate-700">{text}</p>
      </div>
      <div>
        <ol class="grid gap-5 sm:grid-cols-3">
          <li class="border-t border-ink-950/15 pt-5">
            <span class="text-sm font-bold text-gold-700">01</span>
            <h3 class="mt-2 text-lg font-bold text-ink-950">Wyślij zapytanie</h3>
            <p class="mt-2 text-sm leading-7 text-slate-700">Napisz, czy wybierasz sesję online czy w Rzeszowie i podaj dogodny sposób kontaktu.</p>
          </li>
          <li class="border-t border-ink-950/15 pt-5">
            <span class="text-sm font-bold text-gold-700">02</span>
            <h3 class="mt-2 text-lg font-bold text-ink-950">Omów przygotowanie</h3>
            <p class="mt-2 text-sm leading-7 text-slate-700">Krótka rozmowa porządkuje pytania, przebieg spotkania i praktyczne warunki sesji LBL.</p>
          </li>
          <li class="border-t border-ink-950/15 pt-5">
            <span class="text-sm font-bold text-gold-700">03</span>
            <h3 class="mt-2 text-lg font-bold text-ink-950">Potwierdź termin</h3>
            <p class="mt-2 text-sm leading-7 text-slate-700">Po potwierdzeniu formy, ceny i dostępności rezerwujesz wybrany termin sesji.</p>
          </li>
        </ol>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <a class="button-primary" href={siteData.cta.url}>Zapytaj o termin</a>
          <a class="button-secondary" href={siteData.contact.whatsappHref} rel="noopener noreferrer">Napisz przez WhatsApp</a>
          <a class="button-quiet" href={siteData.contact.phoneHref}>Zadzwoń: {siteData.contact.phone}</a>
        </div>
        <p class="mt-4 text-xs leading-6 text-slate-600">
          Sesje regresji LBL oraz kontakt prowadzi
          <a class="font-bold text-ink-900 hover:text-gold-700" href={siteData.instituteLink.lblUrl} rel="noopener noreferrer"> Instytut Regresji</a>.
        </p>
      </div>
    </div>
  </div>
</section>
