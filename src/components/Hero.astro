---
import { Image } from 'astro:assets';
import heroImage from '../assets/regresja-lbl-brama-light.webp';
import { siteData } from '../content/siteData';

interface Props {
  title: string;
  subtitle: string;
  ctaLabel: string;
  ctaHref: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const { title, subtitle, ctaLabel, ctaHref, secondaryLabel, secondaryHref } = Astro.props;
---

<section class="hero-editorial relative isolate overflow-hidden border-b border-ink-950/10 bg-warm-50 text-ink-950">
  <Image
    src={heroImage}
    alt=""
    aria-hidden="true"
    widths={[768, 1280, 1600, 1920]}
    sizes="100vw"
    format="webp"
    loading="eager"
    fetchpriority="high"
    class="absolute inset-0 -z-20 h-full w-full object-cover object-[62%_center] lg:object-center"
  />
  <div class="absolute inset-0 -z-10 bg-warm-50/80 lg:bg-warm-50/40"></div>

  <div class="container-page flex min-h-[34rem] items-center py-8 sm:min-h-[36rem] sm:py-12 lg:min-h-[35rem] lg:py-14">
    <div class="w-full max-w-[43rem]">
      <p class="hero-kicker"><span class="sm:hidden">Regresja LBL · online / Rzeszów</span><span class="hidden sm:inline">Sesja Life Between Lives · online lub Rzeszów</span></p>
      <h1 class="hero-title display-title mt-4 max-w-[42rem] text-balance text-ink-950">{title}</h1>
      <p class="mt-5 max-w-[39rem] text-pretty text-base leading-8 text-ink-800 sm:text-lg sm:leading-8">
        <span class="sm:hidden">Sesja Life Between Lives poświęcona relacjom, poczuciu celu i życiu między wcieleniami. Online lub w Rzeszowie.</span>
        <span class="hidden sm:inline">{subtitle}</span>
      </p>

      <div class="mt-6 flex flex-col gap-3 sm:mt-7 sm:flex-row sm:flex-wrap">
        <a class="button-primary w-full text-center sm:w-auto" href={ctaHref}>{ctaLabel}</a>
        {secondaryLabel && secondaryHref && <a class="button-secondary w-full text-center sm:w-auto" href={secondaryHref}>{secondaryLabel}</a>}
      </div>

      <dl class="hero-facts mt-6 sm:mt-7" aria-label="Najważniejsze informacje o sesji LBL">
        <div>
          <dt>Czas sesji</dt>
          <dd>{siteData.session.duration}</dd>
        </div>
        <div>
          <dt>Forma</dt>
          <dd><span class="sm:hidden">online / Rzeszów</span><span class="hidden sm:inline">{siteData.session.format}</span></dd>
        </div>
        <div>
          <dt>Kontakt</dt>
          <dd><span class="sm:hidden">formularz / telefon</span><span class="hidden sm:inline">telefon, WhatsApp lub formularz</span></dd>
        </div>
      </dl>
    </div>
  </div>
</section>
