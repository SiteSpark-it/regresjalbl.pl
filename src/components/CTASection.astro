---
import { siteData } from '../content/siteData';

interface Props {
  title?: string;
  text?: string;
}

const {
  title = 'Umów konsultację w sprawie sesji',
  text = 'Jeżeli temat wraca do Ciebie od dłuższego czasu, nie musisz od razu decydować o pełnej sesji. Zacznij od krótkiej konsultacji: opisz, czego szukasz, a dostaniesz jasną informację o najbliższym sensownym kroku.'
} = Astro.props;
---

<section class="bg-[#eaf6f8] text-ink-950">
  <div class="container-page grid gap-8 py-14 lg:grid-cols-[1fr_auto] lg:items-center">
    <div>
      <div class="gold-line"></div>
      <h2 class="display-title mt-5 text-4xl md:text-5xl">{title}</h2>
      <p class="mt-5 max-w-3xl text-base leading-8 text-slate-700">{text}</p>
      <div class="trust-strip">
        <span class="trust-pill">1 wiadomość</span>
        <span class="trust-pill">spokojna kwalifikacja</span>
        <span class="trust-pill">kontakt mail / telefon / WhatsApp</span>
      </div>
    </div>
    <div class="flex flex-col gap-3 sm:flex-row lg:flex-col">
      <a class="button-primary" href={siteData.cta.url} aria-label="Przejdź do konsultacji na regresjalbl.pl">{siteData.cta.label}</a>
      <a class="button-secondary bg-white/55" href={siteData.personalLink.url} rel="noopener noreferrer" aria-label="Przejdź do strony Macieja Masłanki">Maciej Masłanka</a>
    </div>
  </div>
</section>
