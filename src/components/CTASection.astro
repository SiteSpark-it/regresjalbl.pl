---
import { siteData } from '../content/siteData';

interface Props {
  title?: string;
  text?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  title = 'Chcesz umówić sesję regresji LBL?',
  text = 'Napisz, czy interesuje Cię spotkanie online czy w Rzeszowie i czego chcesz dowiedzieć się podczas sesji. Otrzymasz informacje o przygotowaniu, aktualnych terminach i dalszym kontakcie.',
  ctaLabel = siteData.cta.label,
  ctaHref = siteData.cta.url
} = Astro.props;
---

<section class="bg-[#eaf6f8] text-ink-950">
  <div class="container-page grid gap-8 py-14 lg:grid-cols-[1fr_0.42fr] lg:items-center">
    <div>
      <h2 class="section-heading">{title}</h2>
      <p class="mt-5 max-w-3xl text-base leading-8 text-slate-700">{text}</p>
      <div class="trust-strip">
        <span class="trust-pill">{siteData.session.duration}</span>
        <span class="trust-pill">{siteData.session.format}</span>
        <span class="trust-pill">{siteData.session.price}</span>
      </div>
    </div>
    <div class="soft-panel p-5">
      <p class="text-sm font-bold text-ink-950">Najkrótsza ścieżka</p>
      <p class="mt-2 text-sm leading-7 text-slate-700">
        Wyślij krótkie zapytanie na tej stronie. Możesz też od razu napisać przez WhatsApp albo zadzwonić do Instytutu Regresji.
      </p>
      <div class="mt-5 grid gap-3">
        <a class="button-primary w-full" href={ctaHref}>{ctaLabel}</a>
        <a class="button-secondary w-full bg-white/70" href={siteData.contact.whatsappHref} rel="noopener noreferrer">WhatsApp</a>
        <a class="button-quiet w-full bg-white/55" href={siteData.contact.emailHref}>{siteData.contact.email}</a>
      </div>
      <p class="mt-4 text-xs leading-6 text-slate-600">
        Sesje LBL i kontakt prowadzi
        <a class="font-bold text-ink-900 hover:text-gold-700" href={siteData.instituteLink.lblUrl} rel="noopener noreferrer">Instytut Regresji</a>.
      </p>
    </div>
  </div>
</section>
