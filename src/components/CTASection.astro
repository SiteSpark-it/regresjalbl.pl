---
import { siteData } from '../content/siteData';

interface Props {
  title?: string;
  text?: string;
}

const {
  title = 'Sesja w Instytucie Regresji',
  text = 'Jeżeli po lekturze czujesz, że to może być dla Ciebie właściwy moment, możesz spokojnie zajrzeć do zapisów w Instytucie Regresji. Tam znajdziesz informacje o terminach, formie sesji i dalszym kontakcie.'
} = Astro.props;
---

<section class="bg-ink-900 text-warm-50">
  <div class="container-page grid gap-8 py-14 lg:grid-cols-[1fr_auto] lg:items-center">
    <div>
      <div class="gold-line"></div>
      <h2 class="display-title mt-5 text-4xl md:text-5xl">{title}</h2>
      <p class="mt-5 max-w-3xl text-base leading-8 text-warm-100/78">{text}</p>
    </div>
    <div class="flex flex-col gap-3 sm:flex-row lg:flex-col">
      <a class="button-primary" href={siteData.cta.url} rel="noopener noreferrer" aria-label="Przejdź do zapisów w Instytucie Regresji">{siteData.cta.label}</a>
      <a class="button-secondary" href={siteData.personalLink.url} rel="noopener noreferrer" aria-label="Przejdź do strony Macieja Masłanki">Maciej Masłanka</a>
    </div>
  </div>
</section>
