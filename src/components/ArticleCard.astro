---
interface Props {
  title: string;
  description: string;
  href: string;
  meta?: string;
}

const { title, description, href, meta = 'artykuł' } = Astro.props;
---

<article class="grid gap-4 border-t border-ink-950/12 py-6 transition duration-200 hover:border-gold-500/45 md:grid-cols-[0.22fr_0.78fr]">
  <p class="text-xs font-bold uppercase tracking-[0.16em] text-gold-700">{meta}</p>
  <div>
    <h3 class="text-2xl font-bold text-ink-950">
      <a class="article-link hover:text-gold-700" href={href}>{title}</a>
    </h3>
    <p class="mt-3 max-w-2xl text-sm leading-7 text-slate-600">{description}</p>
  </div>
</article>
