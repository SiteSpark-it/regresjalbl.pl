---
import { siteData } from '../content/siteData';
const year = new Date().getFullYear();
---

<footer class="bg-ink-950 text-warm-100">
  <div class="container-page grid gap-10 py-14 lg:grid-cols-[1.4fr_1fr_1fr]">
    <section aria-labelledby="footer-about">
      <h2 id="footer-about" class="display-title text-3xl text-warm-50">Regresja LBL</h2>
      <p class="mt-4 max-w-xl text-sm leading-7 text-warm-100/76">
        Edukacyjny przewodnik po pojęciach LBL, Life Between Lives® i regresji między wcieleniami oraz
        odpowiedzialne wprowadzenie do autorskiej metody Brama Dusz LBL™.
      </p>
      <p class="mt-5 text-xs leading-6 text-warm-100/62">{siteData.disclaimer}</p>
    </section>

    <nav aria-labelledby="footer-nav">
      <h2 id="footer-nav" class="text-sm font-bold uppercase tracking-[0.14em] text-gold-500">Nawigacja</h2>
      <ul class="mt-4 grid gap-2 text-sm">
        {siteData.footerLinks.map((link) => <li><a class="text-warm-100/78 hover:text-gold-500" href={link.href}>{link.label}</a></li>)}
        <li><a class="text-warm-100/78 hover:text-gold-500" href="/polityka-prywatnosci/">Prywatność</a></li>
      </ul>
    </nav>

    <section aria-labelledby="footer-contact">
      <h2 id="footer-contact" class="text-sm font-bold uppercase tracking-[0.14em] text-gold-500">Kontakt i źródła</h2>
      <ul class="mt-4 grid gap-2 text-sm text-warm-100/78">
        <li><a class="hover:text-gold-500" href={siteData.contact.phoneHref}>{siteData.contact.phone}</a></li>
        <li><a class="hover:text-gold-500" href={siteData.contact.whatsappHref} rel="noopener noreferrer">WhatsApp: {siteData.contact.phone}</a></li>
        <li><a class="hover:text-gold-500" href={siteData.contact.emailHref}>{siteData.contact.email}</a></li>
        <li><a class="hover:text-gold-500" href={siteData.cta.url} rel="noopener noreferrer" aria-label="Przejdź do zapisów w Instytucie Regresji">Instytut Regresji - zapisy</a></li>
        <li><a class="hover:text-gold-500" href={siteData.personalLink.url} rel="noopener noreferrer" aria-label="Przejdź do strony Macieja Masłanki">{siteData.personalLink.label}</a></li>
        <li><a class="hover:text-gold-500" href={siteData.externalLinks.mni} rel="noopener noreferrer">The Michael Newton Institute</a></li>
      </ul>
    </section>
  </div>
  <div class="border-t border-white/10 py-5">
    <p class="container-page text-xs text-warm-100/58">© {year} {siteData.name}. Strona informacyjna, bez afiliacji z The Michael Newton Institute.</p>
  </div>
</footer>
