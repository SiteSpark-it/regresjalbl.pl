---
import { siteData } from '../content/siteData';
const year = new Date().getFullYear();
---

<footer class="bg-[#e8f4f7] text-ink-900">
  <div class="container-page grid gap-10 py-14 md:grid-cols-2 xl:grid-cols-[1.25fr_0.9fr_0.9fr_1fr]">
    <section aria-labelledby="footer-about">
      <h2 id="footer-about" class="display-title text-3xl text-ink-950">Regresja LBL</h2>
      <p class="mt-4 max-w-xl text-sm leading-7 text-slate-700">
        Praktyczny przewodnik po regresji LBL i Life Between Lives oraz informacje o sesjach prowadzonych przez
        Instytut Regresji — online i stacjonarnie w Rzeszowie.
      </p>
      <p class="mt-5 text-xs leading-6 text-slate-600">Treści mają charakter edukacyjny i rozwojowy. Sesja nie zastępuje pomocy medycznej ani psychoterapii klinicznej.</p>
    </section>

    <nav aria-labelledby="footer-nav">
      <h2 id="footer-nav" class="text-sm font-bold uppercase tracking-[0.14em] text-gold-700">Nawigacja</h2>
      <ul class="mt-4 grid gap-2 text-sm">
        {siteData.footerLinks.map((link) => <li><a class="text-slate-700 hover:text-gold-700" href={link.href}>{link.label}</a></li>)}
        <li><a class="text-slate-700 hover:text-gold-700" href="/polityka-prywatnosci/">Prywatność</a></li>
      </ul>
    </nav>

    <nav aria-labelledby="footer-guides">
      <h2 id="footer-guides" class="text-sm font-bold uppercase tracking-[0.14em] text-gold-700">Popularne pytania</h2>
      <ul class="mt-4 grid gap-2 text-sm">
        <li><a class="text-slate-700 hover:text-gold-700" href="/artykuly/pytania-do-sesji-regresji/">Jak przygotować pytania?</a></li>
        <li><a class="text-slate-700 hover:text-gold-700" href="/artykuly/co-jesli-nic-nie-zobacze-podczas-regresji/">Co, jeśli nic nie zobaczę?</a></li>
        <li><a class="text-slate-700 hover:text-gold-700" href="/artykuly/jak-wybrac-prowadzacego-regresje/">Jak wybrać prowadzącego?</a></li>
        <li><a class="text-slate-700 hover:text-gold-700" href="/artykuly/integracja-po-sesji-regresji/">Co robić po sesji?</a></li>
      </ul>
    </nav>

    <section aria-labelledby="footer-contact">
      <h2 id="footer-contact" class="text-sm font-bold uppercase tracking-[0.14em] text-gold-700">Kontakt i źródła</h2>
      <ul class="mt-4 grid gap-2 text-sm text-slate-700">
        <li><a class="hover:text-gold-700" href={siteData.contact.phoneHref}>{siteData.contact.phone}</a></li>
        <li><a class="hover:text-gold-700" href={siteData.contact.whatsappHref} rel="noopener noreferrer">WhatsApp: {siteData.contact.phone}</a></li>
        <li><a class="hover:text-gold-700" href={siteData.contact.emailHref}>{siteData.contact.email}</a></li>
        <li><a class="hover:text-gold-700" href={siteData.cta.url}>Zapytaj o sesję LBL</a></li>
        <li><a class="hover:text-gold-700" href={siteData.instituteLink.lblUrl} rel="noopener noreferrer">Regresja LBL w Instytucie Regresji</a></li>
        <li><a class="hover:text-gold-700" href={siteData.externalLinks.mni} rel="noopener noreferrer">The Michael Newton Institute</a></li>
      </ul>
    </section>
  </div>
  <div class="border-t border-ink-950/10 py-5">
    <p class="container-page text-xs text-slate-600">© {year} {siteData.name}. Sesje regresji LBL i kontakt prowadzi Instytut Regresji.</p>
  </div>
</footer>
